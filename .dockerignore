node_modules
dist
.git
.claude
.DS_Store
*.log
# Host-side decoder build artifacts. The Dockerfile rebuilds these
# inside dedicated stages; if we let the host bin/ symlinks leak in,
# `cp` inside the container chokes on them as dangling refs (homebrew
# paths like /opt/homebrew/bin/direwolf don't exist in debian-slim).
decoders/*/bin
decoders/*/build
