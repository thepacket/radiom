// FSQ-specific GUI/log hooks.
void display_fsq_rx_text(const std::string& s, int /*style*/) {
  // The decoded text path. Stream printable chars to stdout so the Node
  // wrapper can forward them to the WS client.
  std::fwrite(s.data(), 1, s.size(), stdout);
  std::fflush(stdout);
}
